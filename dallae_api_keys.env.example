# DallaeBaepo — API 키 설정 파일
# DallaeBaepo.exe 와 같은 폴더에 "dallae_api_keys.env" 로 저장 후 값을 채우세요.
# 빌드 시마다 수정 불필요.

# AI 채팅 엔진 (개발자 제공 크레딧 소진 후 필요)
ANTHROPIC_API_KEY_BAEPO=
GEMINI_API_KEY=

# LinaAI 피드백 서버 연동 (개발자 배포 전 설정)
# 유저 신고/전달 메시지를 개발자 서버로 전송합니다.
LINA_SERVER_URL=http://your-lina-server:8000
BAEPO_FORWARD_TOKEN=
